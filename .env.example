# --- Large attachment handling ---
# Attachments larger than this many bytes are compressed (images/GIF/video/
# audio) or linked. Default 10 MB.
MAX_UPLOAD_BYTES=10485760
# Kill an ffmpeg encode that runs longer than this many seconds (then link).
FFMPEG_TIMEOUT_SECONDS=300
# Skip compressing inputs larger than this many bytes (link instead). Default 500 MB.
MAX_COMPRESS_INPUT_BYTES=524288000
